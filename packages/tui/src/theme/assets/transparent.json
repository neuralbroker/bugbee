{
  "$schema": "https://github.com/neuralbroker/bugbee/theme.json",
  "defs": {
    "darkFg": "#f3ebe0",
    "darkMuted": "#8a8078",
    "darkPrimary": "#f0a53a",
    "darkAccent": "#4ecdc4",
    "darkRed": "#e06c75",
    "darkGreen": "#7fd88f",
    "darkYellow": "#e5c07b",
    "darkBorder": "#4e463c",
    "darkMenu": "#1c1916cc",
    "lightFg": "#1a1410",
    "lightMuted": "#8a7f72",
    "lightPrimary": "#c47a12",
    "lightAccent": "#1f6f8b",
    "lightRed": "#c23b3b",
    "lightGreen": "#2f8f5b",
    "lightYellow": "#b0851f",
    "lightBorder": "#d4c8b4",
    "lightMenu": "#f5f0e8cc"
  },
  "theme": {
    "primary": { "dark": "darkPrimary", "light": "lightPrimary" },
    "secondary": { "dark": "darkAccent", "light": "lightAccent" },
    "accent": { "dark": "darkAccent", "light": "lightAccent" },
    "error": { "dark": "darkRed", "light": "lightRed" },
    "warning": { "dark": "darkPrimary", "light": "lightPrimary" },
    "success": { "dark": "darkGreen", "light": "lightGreen" },
    "info": { "dark": "darkAccent", "light": "lightAccent" },
    "text": { "dark": "darkFg", "light": "lightFg" },
    "textMuted": { "dark": "darkMuted", "light": "lightMuted" },
    "selectedListItemText": { "dark": "#0c0b0a", "light": "#fbf8f3" },
    "background": { "dark": "transparent", "light": "transparent" },
    "backgroundPanel": { "dark": "transparent", "light": "transparent" },
    "backgroundElement": { "dark": "transparent", "light": "transparent" },
    "backgroundMenu": { "dark": "darkMenu", "light": "lightMenu" },
    "border": { "dark": "darkBorder", "light": "lightBorder" },
    "borderActive": { "dark": "darkPrimary", "light": "lightPrimary" },
    "borderSubtle": { "dark": "darkBorder", "light": "lightBorder" },
    "diffAdded": { "dark": "darkGreen", "light": "lightGreen" },
    "diffRemoved": { "dark": "darkRed", "light": "lightRed" },
    "diffContext": { "dark": "darkMuted", "light": "lightMuted" },
    "diffHunkHeader": { "dark": "darkMuted", "light": "lightMuted" },
    "diffHighlightAdded": { "dark": "darkGreen", "light": "lightGreen" },
    "diffHighlightRemoved": { "dark": "darkRed", "light": "lightRed" },
    "diffAddedBg": { "dark": "transparent", "light": "transparent" },
    "diffRemovedBg": { "dark": "transparent", "light": "transparent" },
    "diffContextBg": { "dark": "transparent", "light": "transparent" },
    "diffLineNumber": "textMuted",
    "diffAddedLineNumberBg": { "dark": "transparent", "light": "transparent" },
    "diffRemovedLineNumberBg": { "dark": "transparent", "light": "transparent" },
    "markdownText": { "dark": "darkFg", "light": "lightFg" },
    "markdownHeading": { "dark": "darkPrimary", "light": "lightPrimary" },
    "markdownLink": { "dark": "darkAccent", "light": "lightAccent" },
    "markdownLinkText": { "dark": "darkAccent", "light": "lightAccent" },
    "markdownCode": { "dark": "darkGreen", "light": "lightGreen" },
    "markdownBlockQuote": { "dark": "darkYellow", "light": "lightYellow" },
    "markdownEmph": { "dark": "darkYellow", "light": "lightYellow" },
    "markdownStrong": { "dark": "darkPrimary", "light": "lightPrimary" },
    "markdownHorizontalRule": { "dark": "darkMuted", "light": "lightMuted" },
    "markdownListItem": { "dark": "darkPrimary", "light": "lightPrimary" },
    "markdownListEnumeration": { "dark": "darkAccent", "light": "lightAccent" },
    "markdownImage": { "dark": "darkAccent", "light": "lightAccent" },
    "markdownImageText": { "dark": "darkAccent", "light": "lightAccent" },
    "markdownCodeBlock": { "dark": "darkFg", "light": "lightFg" },
    "syntaxComment": { "dark": "darkMuted", "light": "lightMuted" },
    "syntaxKeyword": { "dark": "darkPrimary", "light": "lightPrimary" },
    "syntaxFunction": { "dark": "darkAccent", "light": "lightAccent" },
    "syntaxVariable": { "dark": "darkRed", "light": "lightRed" },
    "syntaxString": { "dark": "darkGreen", "light": "lightGreen" },
    "syntaxNumber": { "dark": "darkYellow", "light": "lightYellow" },
    "syntaxType": { "dark": "darkYellow", "light": "lightYellow" },
    "syntaxOperator": { "dark": "darkAccent", "light": "lightAccent" },
    "syntaxPunctuation": { "dark": "darkFg", "light": "lightFg" }
  }
}
